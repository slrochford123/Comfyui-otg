        setPromptModal({ name, meta: r.meta });
        showToast("Prompt repaired");
      } catch (e: any) {
        setErr(String(e?.message || e));
      }
    },
    [showToast],
  );const retryFromGallery = useCallback(async (name: string) => {
    setErr(null);
