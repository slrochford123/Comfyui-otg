        if (!r?.meta || (!meta?.positivePrompt && !meta?.negativePrompt)) {
          showToast("Repair ran, but prompts are still missing for this item.");
        } else {
          showToast("Prompt repaired");
        }
      } catch (e: any) {
        setErr(String(e?.message || e));
      }
    },
    [showToast],
