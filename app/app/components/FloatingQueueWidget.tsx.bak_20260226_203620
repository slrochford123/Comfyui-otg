'use client';

import React, { useEffect, useMemo, useRef, useState } from 'react';
import { useRouter } from 'next/navigation';
import { useFloatingQueue } from './FloatingQueueProvider';

const POS_KEY = 'otg:queuePos_v3';

type Pos = { x: number; y: number };

type QueueItem = {
  id: string;
  title: string;
  status: 'queued' | 'running' | 'complete' | 'error' | string;
  focusId?: string | null;
  resultName?: string | null;
};

function statusLabel(s: QueueItem['status']) {
  if (s === 'running') return 'running';
  if (s === 'queued') return 'queued';
  if (s === 'complete') return 'complete';
  if (s === 'error') return 'error';
  return String(s || 'queued');
}

function normalizeTitle(raw: string) {
  const t = String(raw || '').replace(/\s+/g, ' ').trim();
  return t || 'job';
}

function simplifyTitle(raw: string) {
  const t = normalizeTitle(raw);
  const low = t.toLowerCase();

  // common presets (keeps UI short)
  if (low.includes('create a picture') || low.includes('create picture') || low.includes('create')) return 'create';
  if (low.includes('anime')) return 'anime';
  if (low.includes('wan')) return 'wan';
  if (low.includes('ltx')) return 'ltx';
  if (low.includes('video')) return 'video';
  if (low.includes('image')) return 'image';

  const first = t.split(' ')[0] || t;
  return first.slice(0, 10).toLowerCase();
}

function shortLine(title: string, status: string) {
  // ASCII only. Avoid unicode em-dash/ellipsis that can render as Ã¢â‚¬â€/Ã¢â‚¬Â¦ in some environments.
  return `${title} ${status}`.trim();
}

export function FloatingQueueWidget() {
  const router = useRouter();
  const { items, isOpen, setOpen, clearAll } = useFloatingQueue();
  const typedItems = items as unknown as QueueItem[];

  const displayItems = useMemo(() => {
    const rank = (s: QueueItem['status']) => {
      if (s === 'running') return 0;
      if (s === 'queued') return 1;
      if (s === 'complete') return 2;
      if (s === 'error') return 3;
      return 9;
    };
    return [...typedItems].sort((a, b) => rank(a.status) - rank(b.status));
  }, [typedItems]);

  const activeCount = useMemo(
    () => typedItems.filter((i) => i.status === 'queued' || i.status === 'running').length,
    [typedItems]
  );

  const hasRunning = useMemo(() => typedItems.some((i) => i.status === 'running'), [typedItems]);
  const badgeCount = activeCount > 0 ? activeCount : typedItems.length;

  const [pos, setPos] = useState<Pos>(() => {
    if (typeof window === 'undefined') return { x: 20, y: 20 };
    try {
      const raw = window.localStorage.getItem(POS_KEY);
      const parsed = raw ? JSON.parse(raw) : null;
      if (parsed && typeof parsed.x === 'number' && typeof parsed.y === 'number') return parsed;
    } catch {}
    return { x: 20, y: 20 };
  });

  const dragRef = useRef<{
    dragging: boolean;
    startClientX: number;
    startClientY: number;
    startX: number;
    startY: number;
    moved: boolean;
    pointerId: number | null;
  }>({
    dragging: false,
    startClientX: 0,
    startClientY: 0,
    startX: 0,
    startY: 0,
    moved: false,
    pointerId: null,
  });

  const prevCountRef = useRef<number>(typedItems.length);
  const [pop, setPop] = useState(false);
  const [lastAddedId, setLastAddedId] = useState<string | null>(null);

  useEffect(() => {
    if (typedItems.length > prevCountRef.current) {
      const newest = typedItems[typedItems.length - 1];
      setLastAddedId(newest?.id ?? null);
      setPop(true);
      const t = setTimeout(() => setPop(false), 260);
      prevCountRef.current = typedItems.length;
      return () => clearTimeout(t);
    }
    prevCountRef.current = typedItems.length;
  }, [typedItems]);

  if (typedItems.length === 0) return null;

  const savePos = (p: Pos) => {
    try {
      window.localStorage.setItem(POS_KEY, JSON.stringify(p));
    } catch {}
  };

  const visible = displayItems.slice(0, 3);
  const remaining = Math.max(0, displayItems.length - visible.length);

  // Inline styles (this project uses custom CSS, not Tailwind utilities)
  const bubbleStyle: React.CSSProperties = {
    width: 56,
    height: 56,
    borderRadius: 9999,
    border: '1px solid rgba(255,255,255,0.14)',
    background: 'linear-gradient(90deg, rgba(168,85,247,0.95), rgba(34,211,238,0.95))',
    color: '#fff',
    fontWeight: 900,
    fontSize: 18,
    lineHeight: '56px',
    textAlign: 'center',
    boxShadow: '0 14px 40px rgba(0,0,0,0.55)',
    cursor: 'pointer',
    position: 'relative',
    transform: pop ? 'scale(1.08)' : 'scale(1)',
    transition: 'transform 160ms ease-out',
  };

  const panelStyle: React.CSSProperties = {
    marginTop: 10,
    width: 280,
    maxWidth: '78vw',
    borderRadius: 18,
    border: '1px solid rgba(255,255,255,0.10)',
    background: 'rgba(8,8,14,0.78)',
    backdropFilter: 'blur(14px)',
    boxShadow: '0 20px 60px rgba(0,0,0,0.60)',
    overflow: 'hidden',
    transformOrigin: 'bottom right',
    transform: isOpen ? 'scale(1) translateY(0px)' : 'scale(0.96) translateY(6px)',
    opacity: isOpen ? 1 : 0,
    pointerEvents: isOpen ? 'auto' : 'none',
    transition: 'opacity 180ms ease, transform 180ms ease',
  };

  return (
    <div
      style={{
        position: 'fixed',
        right: pos.x,
        bottom: pos.y,
        zIndex: 9999,
        userSelect: 'none',
        touchAction: 'none',
      }}
      onPointerDown={(e) => {
        if (e.pointerType === 'mouse' && e.button !== 0) return;

        dragRef.current.dragging = true;
        dragRef.current.pointerId = e.pointerId;
        dragRef.current.startClientX = e.clientX;
        dragRef.current.startClientY = e.clientY;
        dragRef.current.startX = pos.x;
        dragRef.current.startY = pos.y;
        dragRef.current.moved = false;

        (e.currentTarget as HTMLDivElement).setPointerCapture(e.pointerId);
      }}
      onPointerMove={(e) => {
        if (!dragRef.current.dragging) return;
        if (dragRef.current.pointerId !== e.pointerId) return;

        const dx = e.clientX - dragRef.current.startClientX;
        const dy = e.clientY - dragRef.current.startClientY;

        if (Math.abs(dx) > 3 || Math.abs(dy) > 3) dragRef.current.moved = true;

        const nx = Math.max(0, dragRef.current.startX - dx);
        const ny = Math.max(0, dragRef.current.startY - dy);

        setPos({ x: nx, y: ny });
      }}
      onPointerUp={(e) => {
        if (dragRef.current.pointerId !== e.pointerId) return;
        dragRef.current.dragging = false;
        dragRef.current.pointerId = null;
        savePos(pos);
      }}
      onPointerCancel={(e) => {
        if (dragRef.current.pointerId !== e.pointerId) return;
        dragRef.current.dragging = false;
        dragRef.current.pointerId = null;
        savePos(pos);
      }}
    >
      {/* Local keyframes (no Tailwind animate- utilities in this codebase) */}
      <style jsx>{`
        @keyframes otg-ping {
          0% {
            transform: scale(0.92);
            opacity: 0.55;
          }
          80% {
            transform: scale(1.28);
            opacity: 0;
          }
          100% {
            transform: scale(1.28);
            opacity: 0;
          }
        }
        @keyframes otg-pulse {
          0% {
            opacity: 0.12;
          }
          50% {
            opacity: 0.26;
          }
          100% {
            opacity: 0.12;
          }
        }
        @keyframes otg-row-bounce {
          0% {
            transform: translateY(0);
          }
          30% {
            transform: translateY(-2px);
          }
          60% {
            transform: translateY(0);
          }
          100% {
            transform: translateY(0);
          }
        }
      `}</style>

      <button
        type="button"
        aria-label={`Queue: ${badgeCount}`}
        onClick={() => {
          if (dragRef.current.moved) return;
          setOpen(!isOpen);
        }}
        style={bubbleStyle}
      >
        {/* ring effects while running */}
        {hasRunning && (
          <>
            <span
              aria-hidden
              style={{
                position: 'absolute',
                inset: -10,
                borderRadius: 9999,
                background: 'rgba(168,85,247,0.18)',
                animation: 'otg-ping 1.35s cubic-bezier(.2,.8,.2,1) infinite',
              }}
            />
            <span
              aria-hidden
              style={{
                position: 'absolute',
                inset: -6,
                borderRadius: 9999,
                background: 'rgba(34,211,238,0.12)',
                animation: 'otg-pulse 1.2s ease-in-out infinite',
              }}
            />
          </>
        )}

        <span style={{ position: 'relative' }}>{badgeCount}</span>
      </button>

      <div style={panelStyle}>
        <div style={{ padding: 12 }}>
          <div style={{ display: 'flex', flexDirection: 'column', gap: 8 }}>
            {visible.map((item) => {
              const focus = item.focusId || item.resultName;
              const clickable = item.status === 'complete' && !!focus;

              const t = simplifyTitle(item.title);
              const s = statusLabel(item.status);
              const line = shortLine(t, s);

              return (
                <button
                  key={item.id}
                  type="button"
                  disabled={!clickable}
                  onClick={() => {
                    if (!clickable) return;
                    const f = encodeURIComponent(String(focus));
                    router.push(`/app?tab=gallery&focus=${f}`);
                    setOpen(false);
                  }}
                  title={normalizeTitle(item.title)}
                  style={{
                    width: '100%',
                    textAlign: 'left',
                    borderRadius: 14,
                    border: '1px solid rgba(255,255,255,0.10)',
                    background: 'rgba(255,255,255,0.06)',
                    color: '#fff',
                    padding: '10px 12px',
                    fontSize: 13,
                    fontWeight: 700,
                    cursor: clickable ? 'pointer' : 'default',
                    opacity: clickable ? 1 : 0.92,
                    display: 'flex',
                    alignItems: 'center',
                    justifyContent: 'space-between',
                    gap: 10,
                    transform: item.id === lastAddedId ? 'translateY(0)' : undefined,
                    animation: item.id === lastAddedId ? 'otg-row-bounce 600ms ease-out' : undefined,
                  }}
                >
                  <span style={{ overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{line}</span>

                  <span
                    aria-hidden
                    style={{
                      width: 8,
                      height: 8,
                      borderRadius: 9999,
                      background:
                        item.status === 'running'
                          ? '#34d399'
                          : item.status === 'queued'
                            ? '#fbbf24'
                            : item.status === 'complete'
                              ? '#38bdf8'
                              : item.status === 'error'
                                ? '#fb7185'
                                : 'rgba(255,255,255,0.35)',
                      boxShadow:
                        item.status === 'running' ? '0 0 0 4px rgba(52,211,153,0.12)' : undefined,
                    }}
                  />
                </button>
              );
            })}
          </div>

          {remaining > 0 && (
            <div style={{ marginTop: 10, fontSize: 12, opacity: 0.7 }}>
              +{remaining} more
            </div>
          )}

          <button
            type="button"
            onClick={clearAll}
            style={{
              marginTop: 10,
              width: '100%',
              borderRadius: 14,
              border: '1px solid rgba(255,255,255,0.10)',
              background: 'rgba(255,255,255,0.10)',
              color: '#fff',
              padding: '10px 12px',
              fontSize: 12,
              fontWeight: 800,
              cursor: 'pointer',
            }}
          >
            Clear All
          </button>
        </div>
      </div>
    </div>
  );
}
