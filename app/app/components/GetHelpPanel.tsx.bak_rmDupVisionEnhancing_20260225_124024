}

function PrimaryButton(props: React.ButtonHTMLAttributes<HTMLButtonElement>) {
  const { children, ...rest } = props;
  return (
    <button {...rest} className={(`otg-btnPrimary ${props.className || ""}`).trim()}>
      {children}
    </button>
  );
}

async function safeJson(res: Response) {
  const text = await res.text();
  try {
    return { ok: res.ok, status: res.status, data: text ? JSON.parse(text) : null, raw: text };
  } catch {
    return { ok: res.ok, status: res.status, data: null, raw: text };
  }
}

async function uploadStoryboardImage(file: File): Promise<{ serverPath: string }> {
  const fd = new FormData();
  fd.append("image", file, file.name);
  const res = await fetch("/api/storyboard/upload", { method: "POST", headers: withDeviceHeader(), body: fd });
  const j = await safeJson(res);
  if (!j.ok) throw new Error((j.data as any)?.error || j.raw || `Upload failed (${j.status})`);
  if (!(j.data as any)?.serverPath) throw new Error("Upload did not return serverPath");
  return { serverPath: String((j.data as any).serverPath) };
}

async function callVisionPrompt(args: {
  imagePath: string;
  purpose: VisionPurpose;
  promptHint?: string;
}): Promise<{ descriptor: string }> {
  const res = await fetch("/api/vision-prompt", {
    method: "POST",
    headers: { "Content-Type": "application/json", ...withDeviceHeader() },
    body: JSON.stringify(args),
  });
  const j = await safeJson(res);
  if (!j.ok) throw new Error((j.data as any)?.error || j.raw || `Vision failed (${j.status})`);
  return { descriptor: String((j.data as any)?.descriptor || "") };
}

async function callEnhancePrompt(args: {
  text: string;
  mode: "scene";
  size: EnhanceSize;
}): Promise<{ enhanced: string }> {
  const res = await fetch("/api/enhance-prompt", {
    method: "POST",
    headers: { "Content-Type": "application/json", ...withDeviceHeader() },
    body: JSON.stringify(args),
  });
  const j = await safeJson(res);
  if (!j.ok) throw new Error((j.data as any)?.error || j.raw || `Enhance failed (${j.status})`);
  return { enhanced: String((j.data as any)?.enhanced || "") };
}

async function uploadAndTranscribeAudio(blob: Blob, filename = "recording.webm"): Promise<{ text: string }> {
  const fd = new FormData();
  fd.append("audio", blob, filename);
  const res = await fetch("/api/ollama-ai/transcribe", { method: "POST", headers: withDeviceHeader(), body: fd });
  const j = await safeJson(res);
  if (!j.ok) throw new Error((j.data as any)?.error || j.raw || `Transcribe failed (${j.status})`);
  return { text: String((j.data as any)?.text || "").trim() };
}

async function callOllamaPlan(args: {
  transcript: string;
  sceneCount: number;
  secondsPerScene: number;
  style: string;
  cameraAggressiveness: CameraAggressiveness;
  locationStability: LocationStability;
}): Promise<{ plan: any }> {
  const res = await fetch("/api/ollama-ai/plan", {
    method: "POST",
    headers: { "Content-Type": "application/json", ...withDeviceHeader() },
    body: JSON.stringify(args),
  });
  const j = await safeJson(res);
  if (!j.ok) throw new Error((j.data as any)?.error || j.raw || `Plan failed (${j.status})`);
  return { plan: (j.data as any)?.plan };
}

async function callOllamaWrite(args: {
  plan: any;
  format: PromptFormat;
  style: string;
  sceneCount: number;
  secondsPerScene: number;
  cameraAggressiveness: CameraAggressiveness;
  locationStability: LocationStability;
}): Promise<{ promptText: string }> {
  const res = await fetch("/api/ollama-ai/write", {
    method: "POST",
    headers: { "Content-Type": "application/json", ...withDeviceHeader() },
    body: JSON.stringify(args),
  });
  const j = await safeJson(res);
  if (!j.ok) throw new Error((j.data as any)?.error || j.raw || `Write failed (${j.status})`);
  return { promptText: String((j.data as any)?.promptText || "") };
}

function BigSubTabs({ tab, setTab }: { tab: HelpSubTab; setTab: (t: HelpSubTab) => void }) {
  const mk = (id: HelpSubTab, label: string) => {
    const active = tab === id;
    return (
      <button
        type="button"
        onClick={() => setTab(id)}
        className={active ? "otg-btnPrimary" : "otg-btnGhost"}
        style={{ height: 48, paddingLeft: 14, paddingRight: 14, fontWeight: 700, borderRadius: 14 }}
      >
        {label}
      </button>
    );
  };
  return (
    <div className="otg-row" style={{ gap: 10, flexWrap: "wrap", alignItems: "center" }}>
      
      {mk("vision", "Describe Picture")}
      {mk("enhance", "Enhance Prompt")}
      {mk("olama", "Olama AI")}
    </div>
  );
}

