            type="button"
            className={helpSize === "medium" ? "otg-btnPrimary" : "otg-btnGhost"}
            onClick={() => setHelpSize("medium")}
            disabled={helpBusy}
          >
            Medium
          </button>
          <button
            type="button"
            className={helpSize === "large" ? "otg-btnPrimary" : "otg-btnGhost"}
            onClick={() => setHelpSize("large")}
            disabled={helpBusy}
          >
            Large
          </button>
          <GhostButton onClick={onEnhance} disabled={!canEnhance} title={`Enhance prompt (${sizeLabel})`}>
            {helpBusy ? "Enhancing..." : `Enhance (${sizeLabel})`}
          </GhostButton>
        </div>

        <textarea
          value={helpText}
          onChange={(e) => setHelpText(e.target.value)}
          rows={4}
          placeholder="Paste your prompt here..."
          className="otg-textarea"
          style={{ marginTop: 10 }}
        />

        {helpErr ? <div className="otg-error" style={{ marginTop: 10 }}>{helpErr}</div> : null}

        <textarea
          value={helpOut}
          onChange={(e) => setHelpOut(e.target.value)}
          rows={4}
          placeholder="Enhanced prompt will appear here..."
          className="otg-textarea"
          style={{ marginTop: 10 }}
        />

        <div className="otg-row" style={{ marginTop: 10, gap: 8, flexWrap: "wrap" }}>
          <GhostButton onClick={() => copy(helpOut)} disabled={!helpOut.trim()}>
            Copy
          </GhostButton>
          <PrimaryButton
            onClick={() => {
              const t = (helpOut || "").trim();
              if (!t) return;
              onSendToPrompt(t);
              onGotoGenerate();
            }}
            disabled={!helpOut.trim()}
          >
            Send to Prompt
          </PrimaryButton>
        </div>
      </Card>
      ) : null}

      {subTab === "olama" ? (
        <Card title="Olama AI (Voice/Text â†’ Scene Plan â†’ Prompt)">
          <div className="otg-row" style={{ gap: 10, flexWrap: "wrap", alignItems: "center" }}>
            <select
              className="otg-select"
              value={sceneCount}
              onChange={(e) => setSceneCount(Number(e.target.value) || 5)}
              style={{ minWidth: 140 }}
              disabled={olamaBusy}
            >
              <option value={3}>3 scenes</option>
              <option value={5}>5 scenes</option>
              <option value={8}>8 scenes</option>
            </select>
            <select
              className="otg-select"
              value={secondsPerScene}
              onChange={(e) => setSecondsPerScene(Number(e.target.value) || 10)}
              style={{ minWidth: 160 }}
              disabled={olamaBusy}
            >
              <option value={5}>5s/scene</option>
              <option value={10}>10s/scene</option>
              <option value={20}>20s/scene</option>
            </select>
            <select
              className="otg-select"
              value={cameraAggro}
              onChange={(e) => setCameraAggro(e.target.value as CameraAggressiveness)}
              style={{ minWidth: 200 }}
              disabled={olamaBusy}
            >
              <option value="minimal">Camera: Minimal</option>
              <option value="medium">Camera: Medium</option>
              <option value="dynamic">Camera: Dynamic</option>
            </select>
            <select
              className="otg-select"
              value={locationStability}
              onChange={(e) => setLocationStability(e.target.value as LocationStability)}
              style={{ minWidth: 210 }}
              disabled={olamaBusy}
            >
              <option value="locked">Location: Locked</option>
              <option value="allowed">Location: Allowed changes</option>
            </select>
          </div>

          <div style={{ marginTop: 10 }}>
            <div className="otg-row" style={{ gap: 10, flexWrap: "wrap", alignItems: "center" }}>
              <input
                value={style}
                onChange={(e) => setStyle(e.target.value)}
                className="otg-input"
                placeholder='Style (e.g. "realistic cinematic")'
                style={{ flex: 1, minWidth: 220 }}
                disabled={olamaBusy}
              />
              <select
                className="otg-select"
                value={format}
                onChange={(e) => setFormat(e.target.value as PromptFormat)}
                style={{ minWidth: 220 }}
                disabled={olamaBusy}
              >
                <option value="next_scenes">Format: Next Scene 1/2/3...</option>
                <option value="scene_card">Format: Scene Card (Prompt Law)</option>
              </select>
            </div>
          </div>

          <div style={{ marginTop: 12 }}>
            <div className="otg-row" style={{ gap: 8, flexWrap: "wrap", alignItems: "center" }}>
              <GhostButton onClick={isRecording ? stopRecording : startRecording} disabled={!recordingSupported || olamaBusy}>
                {isRecording ? "Stop Mic" : "Start Mic"}
              </GhostButton>
              <GhostButton onClick={transcribe} disabled={!audioBlob || olamaBusy}>
                {olamaBusy ? "Working..." : "Transcribe"}
              </GhostButton>
              <GhostButton onClick={cleanTranscript} disabled={!olamaInput.trim() || olamaBusy}>
                Clean transcript
              </GhostButton>
              {audioUrl ? (
                // eslint-disable-next-line jsx-a11y/media-has-caption
                <audio controls src={audioUrl} style={{ height: 32 }} />
              ) : null}
            </div>
          </div>

          <textarea
            value={olamaInput}
            onChange={(e) => setOlamaInput(e.target.value)}
            rows={5}
            placeholder="Type your story beats, or record and transcribe..."
            className="otg-textarea"
            style={{ marginTop: 10 }}
          />

          {olamaErr ? <div className="otg-error" style={{ marginTop: 10 }}>{olamaErr}</div> : null}

          <div className="otg-row" style={{ marginTop: 10, gap: 8, flexWrap: "wrap" }}>
            <GhostButton onClick={genPlan} disabled={!canOlamaPlan}>
              {olamaBusy ? "Planning..." : "Generate Scene Plan"}
            </GhostButton>
            <GhostButton onClick={genPrompt} disabled={!canOlamaWrite}>
              {olamaBusy ? "Writing..." : "Generate Prompt"}
            </GhostButton>
          </div>

          <div style={{ marginTop: 12 }}>
            <div className="otg-cardTitle" style={{ marginBottom: 6 }}>Scene Plan (editable JSON)</div>
            <textarea
              value={olamaPlanText}
              onChange={(e) => setOlamaPlanText(e.target.value)}
              rows={8}
              placeholder="Scene plan JSON will appear here..."
              className="otg-textarea"
            />
          </div>

          <div style={{ marginTop: 12 }}>
            <div className="otg-cardTitle" style={{ marginBottom: 6 }}>Generated Prompt</div>
            <textarea
              value={olamaPromptOut}
              onChange={(e) => setOlamaPromptOut(e.target.value)}
              rows={8}
              placeholder="Prompt output will appear here..."
              className="otg-textarea"
            />
            <div className="otg-row" style={{ marginTop: 10, gap: 8, flexWrap: "wrap" }}>
              <GhostButton onClick={() => copy(olamaPromptOut)} disabled={!olamaPromptOut.trim()}>
                Copy
              </GhostButton>
              <PrimaryButton
                onClick={() => {
                  const t = (olamaPromptOut || "").trim();
                  if (!t) return;
                  onSendToPrompt(t);
                  onGotoGenerate();
                }}
                disabled={!olamaPromptOut.trim()}
              >
                Send to Prompt
              </PrimaryButton>
            </div>
          </div>
        </Card>
      ) : null}
    </div>
  );
}








