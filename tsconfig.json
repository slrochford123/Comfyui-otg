{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "_local_patches_hold",
    "node_modules",
    "tests",
    "**/*.test.*",
    "**/*.spec.*",
    "**/*.stories.ts",
    "**/*.stories.tsx",
    "**/*.story.ts",
    "**/*.story.tsx",
    ".storybook",
    "storybook-static",
    "files",
    "files/**",
    ".patch",
    ".patch/**",
    "_patch_backups",
    "_patch_backups/**",
    "_otg_patch_backups",
    "_otg_patch_backups/**",
    ".otg_backups",
    ".otg_backups/**",
    ".aider.tags.cache.v4",
    ".aider.tags.cache.v4/**",
    ".codex-backups",
    ".codex-backups/**",
    "otg-improvements-kit",
    "otg-improvements-kit/**",
    "otg-clean-reapply-kit",
    "otg-clean-reapply-kit/**",
    "playwright-report",
    "playwright-report/**",
    "test-results",
    "test-results/**",
    "tmp",
    "tmp/**",
    "patch_*",
    "patch_*/**",
    "patch_gallery_ui_controls_refresh",
    "patch_gallery_ui_controls_refresh/**",
    "backups",
    "backups/**"
  ]
}
