# Server
COMFY_BASE_URL=http://127.0.0.1:8188

# Optional: a base OTG data directory. If set, device galleries default to:
#   ${OTG_DATA_DIR}/device_galleries
OTG_DATA_DIR=

# Preferred: explicit device output root (where synced ComfyUI outputs are saved)
# Example (Windows): C:/Users/<YOU>/comfy-controller/data/device_galleries
# Example (Linux): /srv/otg/device_galleries
OTG_DEVICE_OUTPUT_ROOT=

# Supabase (if used)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=gallery

# Auth
OTG_JWT_SECRET=

# Admin
# Comma-separated emails and/or usernames that are admins.
ADMIN_IDENTIFIERS=

# Admin-only GPU switching
# Option A (recommended): point to a JSON file (avoids dotenv newline/quoting issues)
OTG_COMFY_TARGETS_FILE=

# Option B: inline JSON array (keep on ONE line)
OTG_COMFY_TARGETS=

# Admin Gallery
# Root folder the Admin Gallery can browse. For whole drive on Windows: E:/
ADMIN_GALLERY_ROOT=E:/Renders

# Optional: separate allowlist for admin file serving (recommended).
# If set, admin gallery file/preview routes are restricted to this root.
ADMIN_PATH_ALLOWLIST=E:/

# FFmpeg
# If not set, the server will use `ffmpeg` from PATH.
FFMPEG_PATH=

# Ollama (local LLM)
# Base URL for Ollama server (default http://127.0.0.1:11434)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Vision-capable model name installed in Ollama (examples: llama3.2-vision, llava)
OLLAMA_VISION_MODEL=llama3.2-vision

# Storyboard background removal (Python microservice)
# Start the service in: services/bg_remove
BG_REMOVE_URL=http://127.0.0.1:3333/remove-bg
BG_REMOVE_TIMEOUT_MS=60000
