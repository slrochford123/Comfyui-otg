# Server
COMFY_BASE_URL=http://127.0.0.1:8188

# Optional: a base OTG data directory. If set, device galleries default to:
#   ${OTG_DATA_DIR}/device_galleries
OTG_DATA_DIR=

# Preferred: explicit device output root (where synced ComfyUI outputs are saved)
# Example (Windows): C:/Users/<YOU>/comfy-controller/data/device_galleries
# Example (Linux): /srv/otg/device_galleries
OTG_DEVICE_OUTPUT_ROOT=

# Supabase (if used)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=gallery

# Auth
OTG_JWT_SECRET=
