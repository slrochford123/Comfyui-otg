# Server
COMFY_BASE_URL=http://127.0.0.1:8188

# Optional: a base OTG data directory. If set, device galleries default to:
#   ${OTG_DATA_DIR}/device_galleries
OTG_DATA_DIR=

# Preferred: explicit device output root (where synced ComfyUI outputs are saved)
# Example (Windows): C:/Users/<YOU>/comfy-controller/data/device_galleries
# Example (Linux): /srv/otg/device_galleries
OTG_DEVICE_OUTPUT_ROOT=

# Supabase (if used)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=gallery

# Auth
OTG_JWT_SECRET=

# Admin
# Comma-separated emails and/or usernames that are admins.
ADMIN_IDENTIFIERS=

# Admin-only GPU switching
# Option A (recommended): point to a JSON file (avoids dotenv newline/quoting issues)
OTG_COMFY_TARGETS_FILE=

# Option B: inline JSON array (keep on ONE line)
OTG_COMFY_TARGETS=

# Admin Gallery
# Root folder the Admin Gallery can browse. For whole drive on Windows: E:/
ADMIN_GALLERY_ROOT=E:/Renders

# Optional: separate allowlist for admin file serving (recommended).
# If set, admin gallery file/preview routes are restricted to this root.
ADMIN_PATH_ALLOWLIST=E:/

# FFmpeg
# If not set, the server will use `ffmpeg` from PATH.
FFMPEG_PATH=

# Optional local voice providers
# IndexTTS2 remains the default Text-to-Speech provider.
INDEXTTS2_TTS_COMMAND=
INDEXTTS2_TTS_URL=

# OmniVoice is optional. Configure either a command template or an HTTP endpoint.
# Command templates may use: {text} {prompt} {voice} {speaker} {reference} {output} {output_path} {language}
OMNIVOICE_ROOT=C:/AI/Voices/OmniVoice
OMNIVOICE_TTS_COMMAND=
OMNIVOICE_VIDEO_DUB_COMMAND=
OMNIVOICE_TTS_URL=http://127.0.0.1:7864

# Optional LTX edit LoRA names. Files must exist in ComfyUI models/loras.
OTG_OBSCURA_REMOVA_LORA=LTX23_Obscura_Remova_v1.safetensors
OTG_LTX_VIDEO_REASONING_LORA=Ltx2.3-Licon-VBVR-I2V-390K-R32.safetensors
OTG_LTX_VIDEO_REASONING_STRENGTH=1

# Ollama (local LLM)
# Base URL for Ollama server (default http://127.0.0.1:11434)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Vision-capable model name installed in Ollama (examples: llama3.2-vision, llava)
OLLAMA_VISION_MODEL=redule26/huihui_ai_qwen2.5-vl-7b-abliterated

# Storyboard background removal (Python microservice)
# Start the service in: services/bg_remove
BG_REMOVE_URL=http://127.0.0.1:3333/remove-bg
BG_REMOVE_TIMEOUT_MS=60000
OLLAMA_ENHANCE_MODEL=llama2-uncensored:7b
OLLAMA_SCENE_CREATOR_MODEL=redule26/huihui_ai_qwen2.5-vl-7b-abliterated
OLLAMA_CHAT_MODEL=redule26/huihui_ai_qwen2.5-vl-7b-abliterated


# Angles mesh + Blender Phase 1
# Mesh generation target can stay on the 2nd PC over Tailscale.
OTG_ANGLES_MESH_COMFY_URL=http://100.109.254.63:8188

# Blender runs on the main PC for Send to Blender.
# Multi-view angle assist runs against the 5060 Ti ComfyUI on port 8288.
OTG_ANGLES_MULTIVIEW_COMFY_URL=http://127.0.0.1:8288

OTG_BLENDER_EXE=
OTG_BLENDER_SCRIPT=
OTG_BLENDER_TIMEOUT_MS=180000
OTG_BLENDER_TEXTURE_SIZE=2048
OTG_BLENDER_BAKE_MARGIN=16

# Angles 3D local Hunyuan bridge
# Preferred: point directly to the python.exe inside the working Hunyuan conda env.
# Example: C:/Users/<YOU>/miniconda3/envs/hy3d_clean/python.exe
OTG_HY3D_PYTHON=

# Fallback if OTG_HY3D_PYTHON is not set. `conda` is used by default.
OTG_HY3D_CONDA_EXE=
OTG_HY3D_CONDA_ENV=hy3d_clean

# Root of the working local Hunyuan checkout/environment.
OTG_HY3D_ROOT=C:/AI/Hunyuan3D-2

# Optional explicit bridge script path. Defaults to scripts/angles/hunyuan_bridge.py inside OTG.
OTG_HY3D_BRIDGE_SCRIPT=

# Optional explicit bridge working/output folder. Defaults to ${OTG_DATA_DIR}/tmp/angles_bridge
OTG_HY3D_OUTPUT_DIR=

# Optional bridge/runtime tuning.
OTG_HY3D_TIMEOUT_MS=1800000
OTG_HY3D_DEVICE=cuda
OTG_HY3D_LOW_VRAM=1
OTG_HY3D_SHAPE_MODEL=tencent/Hunyuan3D-2mini
OTG_HY3D_SHAPE_SUBFOLDER=hunyuan3d-dit-v2-mini
OTG_HY3D_TEXTURE_MODEL=tencent/Hunyuan3D-2
