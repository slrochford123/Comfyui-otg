# =========================================================
# OTG / Next.js / Capacitor / ComfyUI .gitignore
# =========================================================
# See https://help.github.com/articles/ignoring-files/
# =========================================================

# -------------------------
# Dependencies
# -------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -------------------------
# Testing / Coverage
# -------------------------
coverage/

# -------------------------
# Next.js
# -------------------------
.next/
out/
build/

# -------------------------
# Capacitor / Mobile
# -------------------------
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/app/release/
android/local.properties
ios/build/
ios/Pods/
ios/DerivedData/

# -------------------------
# Runtime / App Data (CRITICAL)
# -------------------------
data/
device_galleries/
gallery/
galleries/
*.db
*.db-*
*.sqlite
*.sqlite-*
*.jsonl

# -------------------------
# Secrets / Keys / Certs (CRITICAL)
# -------------------------
keys/
*.keystore
*.pem
*.p12
*.crt
*.key

# -------------------------
# Environment files
# -------------------------
.env.local
.env.*.local
.env.production
.env.production.local
.env.test
.env.test.local

# Allow example template only
!.env.example

# -------------------------
# Logs / Debug
# -------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# -------------------------
# Archives / Temp
# -------------------------
*.zip
*.tar
*.tar.gz
*.7z

# -------------------------
# OS / Editor junk
# -------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/

# -------------------------
# Vercel
# -------------------------
.vercel

# -------------------------
# TypeScript
# -------------------------
*.tsbuildinfo
next-env.d.ts

# -------------------------
# PM2 / Process
# -------------------------
pm2.log
ecosystem*.log

# -------------------------
# Misc safety
# -------------------------
.cache/
.tmp/
.temp/
