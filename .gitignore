# =========================================================
# OTG / Next.js / Capacitor / ComfyUI .gitignore
# =========================================================
# See https://help.github.com/articles/ignoring-files/
# =========================================================

# -------------------------
# Dependencies
# -------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -------------------------
# Testing / Coverage
# -------------------------
coverage/

# -------------------------
# Next.js
# -------------------------
.next/
out/
build/

# -------------------------
# Capacitor / Mobile
# -------------------------
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/app/release/
android/release/
android/keystore.properties
android/local.properties
keystore.properties
ios/build/
ios/Pods/
ios/DerivedData/

# -------------------------
# Runtime / App Data (CRITICAL)
# -------------------------
data/
device_galleries/
gallery/
galleries/
*.db
*.db-*
*.sqlite
*.sqlite-*
*.jsonl

# -------------------------
# Secrets / Keys / Certs (CRITICAL)
# -------------------------
keys/
*.keystore
*.pem
*.p12
*.crt
*.key

# -------------------------
# Environment files
# -------------------------
.env.local
.env.*.local
.env.production
.env.production.local
.env.test
.env.test.local

# Allow example template only
!.env.example

# -------------------------
# Logs / Debug
# -------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# -------------------------
# Archives / Temp
# -------------------------
*.zip
*.tar
*.tar.gz
*.7z

# -------------------------
# OS / Editor junk
# -------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/

# -------------------------
# Vercel
# -------------------------
.vercel

# -------------------------
# TypeScript
# -------------------------
*.tsbuildinfo
next-env.d.ts

# -------------------------
# PM2 / Process
# -------------------------
pm2.log
ecosystem*.log

# -------------------------
# Python
# -------------------------
.venv/
venv/
**/.venv/
**/venv/
__pycache__/
*.pyc
*.safetensors
*.safetensors.hash

# -------------------------
# Misc safety
# -------------------------
.cache/
.tmp/
.temp/
_backups/
loras/
uploads/
tmp/
pids/

OTG/
OTG/


# local patch artifacts / backups (never commit)
backups/
_patch_backups/
_local_patches_hold/
.codex-backups/
.otg_backups/
.otg_patch_backups/
_otg_patch_backups/
otg-clean-reapply-kit/
otg-improvements-kit/
patch_full_feature_batch/
release/
playwright-report/
test-results/
.bak/
ssh/
*.bak.*
android/app/build.gradle.bad-state-before-android-rerun.*
*.bak
*.lnk
.env
.aider*
Java/
dev-*.log
repo folder test app.zip
comfy-history-latest.json
baseline-i2v-5s-audio-*.json
